datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         String    @default("HR_MANAGER") // Roles: HR_ADMIN, HR_MANAGER, DEPT_MANAGER, EMPLOYEE, FINANCE, PAYROLL
  employeeId   String?   @unique
  employee     Employee? @relation(fields: [employeeId], references: [id])
}

model Employee {
  id           String         @id @default(uuid())
  employeeCode String         @unique
  name         String
  department   String
  level        String
  country      String
  startDate    DateTime
  isActive     Boolean        @default(true)
  
  // Self-referential manager relation
  managerId    String?
  manager      Employee?      @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates Employee[]     @relation("EmployeeManager")
  
  // Relations
  salaries     SalaryRecord[]
  user         User?
  documents    Document[]

  @@index([name])
  @@index([startDate])
  @@index([department])
  @@index([country])
  @@index([level])
  @@index([isActive, department, level, country])
}

model Document {
  id              String            @id @default(uuid())
  employeeId      String
  employee        Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fileName        String
  originalName    String
  categoryId      String
  category        DocumentCategory  @relation(fields: [categoryId], references: [id])
  description     String?
  fileType        String            // e.g. "pdf", "docx", "png"
  fileSize        Int               // in bytes
  uploadedBy      String?           // Email of user who uploaded
  storageProvider String            // e.g. "cloudinary", "local"
  storagePath     String            // Reference/ID in cloud storage
  downloadUrl     String
  previewUrl      String?
  expiryDate      DateTime?
  version         Int               @default(1)
  isConfidential  Boolean           @default(false)
  tags            DocumentTag[]     // Implicit many-to-many relation
  versions        DocumentVersion[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([employeeId])
  @@index([categoryId])
  @@index([createdAt])
}

model DocumentVersion {
  id            String   @id @default(uuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber Int
  fileName      String
  fileSize      Int
  storagePath   String
  downloadUrl   String
  uploadedBy    String?
  createdAt     DateTime @default(now())

  @@index([documentId])
}

model DocumentCategory {
  id        String     @id @default(uuid())
  name      String     @unique
  isCustom  Boolean    @default(true)
  documents Document[]
  createdAt DateTime   @default(now())
}

model DocumentTag {
  id        String     @id @default(uuid())
  name      String     @unique
  documents Document[] // Implicit many-to-many
  createdAt DateTime   @default(now())
}

// RATIONALE FOR APPEND-ONLY SALARY RECORDS:
// Compensation changes are append-only to preserve a complete, auditable timeline of historical changes.
// Rather than overwriting, a new SalaryRecord is appended, which allows calculation of historical trends,
// back-dated pay analyses, and prevents accidental data loss.
model SalaryRecord {
  id             String   @id @default(uuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  baseAmount     Float    // Native currency base amount
  currency       String   // e.g. "USD", "INR", "EUR"
  bonusAmount    Float    // Native currency bonus amount
  baseAmountUSD  Float    // Normalized base amount in USD
  bonusAmountUSD Float    // Normalized bonus amount in USD
  effectiveDate  DateTime
  createdAt      DateTime @default(now())

  @@index([employeeId, effectiveDate])
}

model CompensationBand {
  id         String @id @default(uuid())
  department String
  level      String
  country    String
  minAmount  Float
  midAmount  Float
  maxAmount  Float
  currency   String

  @@index([department, level, country])
}

model MarketBenchmark {
  id              String @id @default(uuid())
  department      String
  level           String
  country         String
  benchmarkAmount Float
  currency        String
  percentile      Int
  sourceLabel     String @default("Seeded illustrative data — not a live market feed")
}

// RATIONALE FOR APPEND-ONLY AUDIT LOG ENTRIES:
// Audit log entries must be immutable and append-only to provide an untamperable and secure history
// of actions (such as edits, creations, deactivations, and bulk actions) performed within the system.
model AuditLogEntry {
  id          String   @id @default(uuid())
  actorLabel  String   // e.g., email or identifier of the user
  action      String   // e.g., "CREATE", "UPDATE", "DEACTIVATE", "BULK_UPDATE"
  entityType  String   // e.g., "EMPLOYEE", "SALARY"
  entityId    String   // ID of the target record
  beforeValue Json?   // JSON representing the before state
  afterValue  Json?   // JSON representing the after state
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
}

model SavedReport {
  id         String   @id @default(uuid())
  name       String
  definition String   // JSON configuration string containing chosen dimensions, metrics, filters
  createdAt  DateTime @default(now())
}
